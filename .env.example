# ============================================================================
# CONFIGURATION AD WEB INTERFACE
# ============================================================================
#
# IMPORTANT - SÉCURITÉ:
# 1. Copiez ce fichier vers .env: cp .env.example .env
# 2. Générez une SECRET_KEY forte (voir ci-dessous)
# 3. Activez HTTPS en production (obligatoire)
# 4. Désactivez FLASK_DEBUG en production
# 5. Ne committez JAMAIS le fichier .env dans git
#
# ============================================================================

# ----------------------------------------------------------------------------
# CONFIGURATION FLASK (OBLIGATOIRE)
# ----------------------------------------------------------------------------

# SECRET_KEY: Clé secrète pour le chiffrement des sessions et CSRF
# ⚠️  CRITIQUE: Générez une clé forte avec:
#     python -c 'import secrets; print(secrets.token_hex(32))'
# ⚠️  Ne laissez JAMAIS la valeur par défaut en production!
SECRET_KEY=

# MODE DEBUG
# ⚠️  SÉCURITÉ: Mettez à 'false' en production
# En mode debug, les erreurs détaillées sont affichées (risque de fuite d'informations)
# Activez pour le débogage avec Flask Debug Toolbar
FLASK_DEBUG=true
FLASK_ENV=development

# ----------------------------------------------------------------------------
# CONFIGURATION SERVEUR
# ----------------------------------------------------------------------------

# Interface réseau (0.0.0.0 = toutes les interfaces, 127.0.0.1 = localhost uniquement)
AD_WEB_HOST=0.0.0.0
AD_WEB_PORT=5000

# ----------------------------------------------------------------------------
# CONFIGURATION SESSION ET HTTPS
# ----------------------------------------------------------------------------

# SESSION_COOKIE_SECURE: Cookies transmis uniquement via HTTPS
# ⚠️  SÉCURITÉ: true en production (HTTPS requis), false seulement en dev local
SESSION_COOKIE_SECURE=true

# Durée de session en minutes (défaut: 30)
SESSION_TIMEOUT=30

# FORCE_HTTPS: Redirige automatiquement HTTP vers HTTPS
# ⚠️  SÉCURITÉ: true recommandé en production
FORCE_HTTPS=true

# TRUSTED_PROXIES: Liste des IPs de proxys de confiance (pour X-Forwarded-Proto)
# Requis si derrière un reverse proxy (nginx, traefik, etc.)
# TRUSTED_PROXIES=127.0.0.1,::1,10.0.0.0/8

# ----------------------------------------------------------------------------
# CONFIGURATION ACTIVE DIRECTORY (optionnel - peut être configuré via l'interface)
# ----------------------------------------------------------------------------

AD_SERVER=
AD_PORT=389
AD_USE_SSL=false
AD_BASE_DN=

# ----------------------------------------------------------------------------
# CONFIGURATION RBAC (Role-Based Access Control)
# ----------------------------------------------------------------------------

# Activer le contrôle d'accès basé sur les rôles
# Rôles disponibles: admin, operator, reader
RBAC_ENABLED=true

# Rôle par défaut pour les nouveaux utilisateurs (si aucun groupe AD ne correspond)
# ⚠️  SÉCURITÉ: 'reader' recommandé (privilège minimum)
DEFAULT_ROLE=reader

# Attribution automatique des rôles basée sur les groupes AD
# Noms de groupes AD (CN) séparés par des virgules
# Le premier groupe correspondant détermine le rôle (ordre: admin > operator > reader)

# Groupes AD qui donnent le rôle 'admin' (accès complet + administration)
RBAC_ADMIN_GROUPS=Domain Admins,Administrateurs du domaine

# Groupes AD qui donnent le rôle 'operator' (lecture + écriture)
# RBAC_OPERATOR_GROUPS=IT Support,Helpdesk

# Groupes AD qui donnent le rôle 'reader' (lecture seule)
# RBAC_READER_GROUPS=Domain Users

# ----------------------------------------------------------------------------
# CHEMINS PERSONNALISÉS (optionnel - détection automatique par défaut)
# ----------------------------------------------------------------------------

# Windows: C:/ProgramData/ADWebInterface/logs
# Linux: /var/log/ad-web-interface
# AD_LOG_DIR=
# AD_DATA_DIR=
# AD_BACKUP_DIR=

# ----------------------------------------------------------------------------
# CONFIGURATION SMTP (optionnel - pour les notifications par email)
# ----------------------------------------------------------------------------

# Serveur SMTP
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Identifiants SMTP
SMTP_USERNAME=
SMTP_PASSWORD=

# Expéditeur et destinataires
SMTP_FROM=adweb@example.com
EMAIL_TO=admin@example.com

# Activer les notifications email
EMAIL_ENABLED=false

# ----------------------------------------------------------------------------
# AUTRES OPTIONS
# ----------------------------------------------------------------------------

# Nombre d'éléments par page
ITEMS_PER_PAGE=25

# Activer/Désactiver les mises à jour automatiques
AUTO_UPDATE_CHECK=true

# ----------------------------------------------------------------------------
# FEATURE FLAGS - MODULARITÉ (OPTIONNEL)
# ----------------------------------------------------------------------------
# Chaque fonctionnalité peut être activée (true) ou désactivée (false)
# Par défaut, TOUTES les fonctionnalités sont ACTIVÉES

# Gestion des utilisateurs
FEATURE_USERS_ENABLED=true
FEATURE_CREATE_USER_ENABLED=true
FEATURE_EDIT_USER_ENABLED=true
FEATURE_DELETE_USER_ENABLED=true
FEATURE_IMPORT_USERS_ENABLED=true
FEATURE_EXPORT_USERS_ENABLED=true

# Gestion des groupes
FEATURE_GROUPS_ENABLED=true
FEATURE_CREATE_GROUP_ENABLED=true
FEATURE_EDIT_GROUP_ENABLED=true
FEATURE_DELETE_GROUP_ENABLED=true

# Gestion des ordinateurs
FEATURE_COMPUTERS_ENABLED=true
FEATURE_LAPS_ENABLED=true
FEATURE_BITLOCKER_ENABLED=true

# Gestion des OUs
FEATURE_OUS_ENABLED=true

# Outils avancés
FEATURE_RECYCLE_BIN_ENABLED=false
FEATURE_LOCKED_ACCOUNTS_ENABLED=false
FEATURE_EXPIRING_ACCOUNTS_ENABLED=true
FEATURE_PASSWORD_POLICY_ENABLED=true
FEATURE_PASSWORD_AUDIT_ENABLED=true

# Administration
FEATURE_AUDIT_LOGS_ENABLED=true
FEATURE_BACKUPS_ENABLED=true
FEATURE_DIAGNOSTIC_ENABLED=true
FEATURE_API_DOCS_ENABLED=true
FEATURE_SETTINGS_ENABLED=true

# Fonctionnalités utilisateur
FEATURE_FAVORITES_ENABLED=true
FEATURE_TEMPLATES_ENABLED=true
FEATURE_DARK_MODE_ENABLED=true
FEATURE_LANGUAGE_SWITCH_ENABLED=false

# Système
FEATURE_UPDATE_CHECK_ENABLED=true
FEATURE_PWA_ENABLED=true
